{
    "keyboard_name": "LILT5R Mk2",
    "manufacturer": "StanNu",
    "maintainer": "StanNu",
    "url": "https://github.com/qmk/qmk_firmware",
    "usb": {
        "device_version": "2.0.0",
        "pid": "0x0001",
        "vid": "0xFEED"
    },
    "width": 6,
    "height": 1,
    "processor": "RP2040",
    "bootloader": "rp2040",
    // "board": "seeeduino_xiao_rp2040",
    "features": {
        "encoder": true
    },

    "matrix_pins": {
        "direct": [
            ["GP28", "GP2", "GP29", "GP1", "GP6", "GP0"]
        ]
    },

    "encoder": {
        "rotary": [
            { "pin_a": "GP7", "pin_b": "GP27", "resolution": 2 }
        ]
    },

    "via": {
        "layout_options_size": 0,
        "forward_diacritic": false
    },

    "dynamic_keymap": {
        "layer_count": 6
    },

    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},
                {"matrix": [0, 2], "x": 2, "y": 0},
                {"matrix": [0, 3], "x": 3, "y": 0},
                {"matrix": [0, 4], "x": 4, "y": 0},
                {"matrix": [0, 5], "x": 5, "y": 0}
            ]
        }
    }
}